# briefing-v3 secrets (不要提交到 git, .gitignore 已排除)
# 服务器 cron 启动时加载。

# LLM
OPENAI_API_KEY=sk-REPLACE-WITH-YOUR-OPENAI-OR-CODEX-KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Slack webhooks
# 测试频道 (默认推送, 任何 briefing run 不 --target auto 都只推这里)
SLACK_TEST_WEBHOOK=https://hooks.slack.com/services/REPLACE/WITH/YOUR_TEST_WEBHOOK
# 正式频道 (有同事和领导,  只在 target=auto 且 gate 通过时推)
SLACK_PROD_WEBHOOK=https://hooks.slack.com/services/REPLACE/WITH/YOUR_PROD_WEBHOOK

# v1.0.0 Hextra 迁移：对外访问的每日日报 URL 模板。
# 占位符：
#   {{DATE}}       → YYYY-MM-DD
#   {{YEARMONTH}}  → YYYY-MM
# Slack "查看完整早报" 按钮会替换占位符后直接跳转。
BRIEFING_REPORT_URL_BASE=https://<your-cloudflared-hostname>.trycloudflare.com/{{YEARMONTH}}/{{DATE}}/

# Hextra (Hugo) 前端基座路径 + Hugo 可执行路径。
# run 里的 pipeline 会写 {HEXTRA_SITE_DIR}/content/cn/YYYY-MM/YYYY-MM-DD.md
# 并在 HUGO_BIN 存在时调 `hugo --source $HEXTRA_SITE_DIR --minify`。
HEXTRA_SITE_DIR=/root/ai-daily-site
HUGO_BIN=/usr/local/bin/hugo
